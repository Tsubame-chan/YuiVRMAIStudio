# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_VISION_DETAIL=auto
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_TRANSLATE_MODEL=gpt-realtime-translate
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_VOICE=coral
OPENAI_MAX_OUTPUT_TOKENS=600
OPENAI_VISION_MAX_OUTPUT_TOKENS=1200

# Google Gemini
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# Local services
VOICEVOX_BASE_URL=http://127.0.0.1:50021
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Backend
APP_VERSION=0.1.0-alpha.1
CHARACTER_NAME=Yui
DATABASE_URL=sqlite:///./data/yui.db

# User
DEFAULT_USER_ID=local_user

# Provider selection
CHAT_PROVIDER=openai
VISION_PROVIDER=openai
TTS_PROVIDER=voicevox
STT_PROVIDER=openai

# Limits
DAILY_CHAT_LIMIT=300
DAILY_VISION_LIMIT=100
DAILY_STT_MINUTES_LIMIT=60
DAILY_TTS_LIMIT=300

# Character controls
AVAILABLE_FACES=Neutral,Joy,Fun,Angry,Sorrow,Surprised
AVAILABLE_ANIMATIONS=idle_normal,idle_relaxed,nod_small,nod_big,wave_small,wave_big,thinking,surprised_body,happy_body,troubled_body,proud_pose,tsukkomi_point,look_away,talk_gesture_small
